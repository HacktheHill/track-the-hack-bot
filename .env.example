DISCORD_TOKEN=
CLIENT_ID=
COMMUNITY_GUILD_ID=
ORGANIZER_GUILD_ID=
ORGANIZER_GUILD_MEMBER_ROLE_ID=
COMMUNITY_GUILD_HACKER_ROLE_ID=
COMMUNITY_GUILD_ORGANIZER_ROLE_ID=
ORGANIZER_GUILD_ORGANIZER_ROLE_ID=
ORGANIZER_GUILD_EXECUTIVE_ROLE_ID=
LOG_CHANNEL_ID=
TRACK_THE_HACK_URL=
INTERNAL_API_SECRET=

# Optional outreach evidence integration. Configure all values together.
OUTREACH_SERVICE_URL=
OUTREACH_DISCORD_KEY_ID=
OUTREACH_DISCORD_SIGNING_SECRET=
OUTREACH_DISCORD_ALLOWED_CHANNEL_IDS=

# OpenProject integration. The bot leaves this feature disabled if required values are absent.
OPENPROJECT_BASE_URL=https://project.ctn-rtc.org
OPENPROJECT_API_KEY=
DATABASE_URL=

# JSON objects keyed by Discord snowflake IDs.
OPENPROJECT_USER_MAP={}
# Discord category IDs mapped to OpenProject project IDs.
OPENPROJECT_CATEGORY_PROJECT_MAP={}
# Value: {"projectId":18,"openProjectGroupId":21,"priority":1,"accountableDiscordId":"123"}
OPENPROJECT_TEAM_ROLE_MAP={}
OPENPROJECT_BLOCKED_CHANNEL_IDS=[]
# IDs of channels or categories excluded from task creation and AI extraction.
# Category IDs also exclude all descendant channels.
OPENPROJECT_EXCLUDED_CHANNEL_IDS=[]

# Azure OpenAI is optional and uses the Container App's managed identity; do
# not add an API key. Uncomment both values to enable AI extraction.
# AZURE_OPENAI_ENDPOINT=https://example.openai.azure.com
AZURE_OPENAI_API_VERSION=v1
# AZURE_OPENAI_DEPLOYMENT=task-extraction
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
AZURE_OPENAI_MAX_COMPLETION_TOKENS=1024
OPENPROJECT_AI_MAX_CONTEXT_CHARS=16000
OPENPROJECT_AI_MAX_IMAGE_ATTACHMENTS=8

# off: explicit requests only; shadow: store proposals; review: post review cards.
OPENPROJECT_AUTOMATION_MODE=off
OPENPROJECT_RAG_MODE=off
OPENPROJECT_AI_SIGNIFICANCE_THRESHOLD=0.5
OPENPROJECT_AI_EVALUATION_RETENTION_DAYS=90
OPENPROJECT_RAG_SYNC_INTERVAL_SECONDS=600
OPENPROJECT_RAG_SIMILARITY_THRESHOLD=0.82
OPENPROJECT_RUN_MIGRATIONS=true
OPENPROJECT_BATCH_IDLE_SECONDS=300
OPENPROJECT_DEFAULT_START_TODAY=true
OPENPROJECT_DEFAULT_DUE_DAYS=7
OPENPROJECT_SIZE_CUSTOM_FIELD=customField2
OPENPROJECT_DEFAULT_TYPE_NAME=Task
OPENPROJECT_CACHE_TTL_MS=300000
OPENPROJECT_PROPOSAL_RETENTION_DAYS=30
OPENPROJECT_AUDIT_RETENTION_DAYS=365
OPENPROJECT_DRAFT_TTL_MINUTES=1440
BOT_TIME_ZONE=America/Toronto
