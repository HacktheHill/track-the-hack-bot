{
	"name": "track-the-hack-bot",
	"version": "1.0.0",
	"description": "A Discord bot that automatically assigns roles to verified hackers on the Hack the Hill server, integrating with the Track the Hack event management platform.",
	"main": "bot.js",
	"type": "module",
	"scripts": {
		"start": "node dist/bot.js",
		"build": "tsc",
		"test": "npm run build && node --test test/*.test.js",
		"evaluate:ai": "npm run build && node dist/evaluate-ai.js",
		"sync:embeddings": "npm run build && node dist/sync-embeddings.js",
		"migrate:db": "npm run build && node dist/migrate-db.js",
		"dev": "npx nodemon --exec npx tsx src/bot.ts",
		"register": "npx tsx src/register.ts"
	},
	"dependencies": {
		"@azure/identity": "^4.13.1",
		"body-parser": "^2.3.0",
		"discord.js": "^14.26.5",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"pg": "^8.22.0",
		"zod": "^4.4.3"
	},
	"engines": {
		"node": ">=24.0.0 <25"
	},
	"overrides": {
		"undici": "6.27.0"
	},
	"author": "Hack the Hill",
	"license": "MIT",
	"devDependencies": {
		"@types/body-parser": "^1.19.6",
		"@types/express": "^5.0.6",
		"@types/node": "^24.13.3",
		"@types/pg": "^8.20.0",
		"typescript": "^7.0.2"
	}
}
