{
	"name": "track-the-hack-bot",
	"version": "1.0.0",
	"description": "A Discord bot that automatically assigns roles to verified hackers on the Hack the Hill server, integrating with the Track the Hack event management platform.",
	"main": "bot.js",
	"type": "module",
	"scripts": {
		"start": "node dist/bot.js",
		"build": "tsc",
		"test": "npm run build && node --test test/*.test.js",
		"dev": "npx nodemon --exec npx tsx src/bot.ts",
		"register": "npx tsx src/register.ts"
	},
	"dependencies": {
		"@azure/identity": "^4.13.1",
		"body-parser": "^1.19.1",
		"discord.js": "^14.0.0",
		"dotenv": "^16.4.5",
		"express": "^4.21.1",
		"pg": "^8.22.0",
		"zod": "^4.4.3"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"author": "Hack the Hill",
	"license": "MIT",
	"devDependencies": {
		"@types/body-parser": "^1.19.5",
		"@types/express": "^4.17.21",
		"@types/node": "^20.14.12",
		"@types/pg": "^8.20.0",
		"typescript": "^5.5.4"
	}
}
